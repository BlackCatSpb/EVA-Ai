```gitignore
# Python compiled files
__pycache__/
*.pyc
*.pyo
*.pyd

# Dependencies
.venv/
venv/
env/
.env
.env.local
*.env.*

# Logs and temporary files
*.log
*.tmp
*.swp
*.swo

# IDE and editor files
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# OS generated files
.DS_Store
Thumbs.db

# Coverage reports
.coverage
coverage/
htmlcov/

# Build and distribution
dist/
build/
*.egg-info/
target/

# Testing
.pytest_cache/
.mypy_cache/
.tox/

# Security and system
.DS_Store
ehthumbs.db
Icon?
```