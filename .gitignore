```gitignore
# Python compiled files
__pycache__/
*.pyc
*.pyo
*.pyd

# Dependencies
.venv/
venv/
.env
.env.local
*.env.*

# Logs and temporary files
*.log
*.tmp

# Editors and IDEs
.vscode/
.idea/
*.swp
*.swo

# Build and distribution
dist/
build/
*.egg-info/

# Testing and coverage
.coverage
coverage/
htmlcov/
.pytest_cache/
.mypy_cache/
```