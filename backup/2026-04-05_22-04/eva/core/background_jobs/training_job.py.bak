"""
TrainingJob: запуск обучения модели графа памяти
"""
from __future__ import annotations
import logging
import time
from typing import Any
from .base_job import BaseJob, CommandPriority

logger = logging.getLogger("eva.core.autopilot.training")


class TrainingJob(BaseJob):
    job_type = "TrainingJob"
    resource_class = "GPU"
    default_priority = CommandPriority.MEDIUM

    def run(self, context: dict) -> None:
        brain = self.brain
        trainer = getattr(brain, 'memory_graph_trainer', None)
        if trainer is None:
            sa = getattr(brain, 'self_analyzer', None)
            trainer = getattr(sa, 'memory_graph_trainer', None) if sa else None
        if trainer is None:
            logger.info("TrainingJob: тренер недоступен, пропуск")
            return

        # Простой запуск async обучения (делегируем прогресс GUI/тренеру)
        try:
            ok = bool(trainer.train_async()) if hasattr(trainer, 'train_async') else False
            if ok:
                logger.info("TrainingJob: обучение запущено")
            else:
                logger.warning("TrainingJob: не удалось запустить обучение")
        except Exception as e:
            logger.error(f"TrainingJob: ошибка запуска обучения: {e}", exc_info=True)

        # Если есть метод is_training — подождём короткое время для кооперативной паузы
        start = time.time()
        while time.time() - start < 2.0:  # короткий hold, чтобы не засорять очередь многократными триггерами
            if context.get('should_pause', lambda: False)():
                time.sleep(0.2)
            else:
                time.sleep(0.2)
