{
  "hybrid_cache": {
    "max_memory_tokens": 50000,
    "target_memory_gb": 2.0,
    "max_disk_cache_gb": 50.0,
    "dynamic_memory_limit": true,
    "max_ram_usage_percent": 75.0,
    "vram_threshold": 0.15,
    "ram_threshold": 0.12,
    "eviction_policy": "hybrid",
    "hot_threshold": 5,
    "cache_ttl": 86400,
    "min_relevance_score": 0.3,
    "max_context_tokens": 2000,
    "system_free_mem_threshold": 0.15,
    "memory_pressure_interval_s": 2.0,
    "pressure_offload_batch": 64
  },
  "token_cache": {
    "disk_storage_path": "cogniflex_cache/ml_unit/token_cache",
    "max_size_gb": 50.0,
    "compression_enabled": true,
    "index_batch_size": 1000
  },
  "memory_management": {
    "auto_cleanup": true,
    "cleanup_interval_s": 300,
    "max_cache_age_hours": 720,
    "disk_usage_threshold": 0.9
  }
}
